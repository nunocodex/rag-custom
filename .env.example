# --- RAG Server ---
API_PORT=8080
HOST_DOCS_DIR=./tech-docs
CHROMA_COLLECTION=rag_collection
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=llama3.1:8b
MAX_UPLOAD_SIZE=33554432  # 32 MB (in bytes)
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# --- SearXNG ---
SEARXNG_SECRET_KEY=your-secure-secret-key-here

# --- Collection Service ---
TTL_DAYS_DEFAULT=30
TRUST_SCORE_MIN=3
SCHEDULE_INTERVAL_HOURS=24
